# Kopyala: `cp .env.example .env` (Windows: copy .env.example .env)
# .env asla Git'e eklenmez (.gitignore).

# Groq — Expo / Metro istemci paketinde kullanım için (build sırasında gömülür).
# Üretimde anahtarı yalnızca güvenilir ortamlarda tutun; mümkünse backend proxy tercih edin.
EXPO_PUBLIC_GROQ_API_KEY=

# İsteğe bağlı: aynı anahtarı burada da tanımlayabilirsiniz (kod önce EXPO_PUBLIC_* sonra bunu okur).
# GROQ_API_KEY=

# Supabase (projede kullanılıyorsa)
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=
